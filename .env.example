# ── Backend environment variables (set these in Railway / Render) ─────────────
# Judge0 code execution — sign up at rapidapi.com and subscribe to judge0-ce
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=judge0-ce.p.rapidapi.com

# Allowed frontend origin(s) — set to your Vercel deployment URL
# Multiple origins: CORS_ORIGIN=https://a.vercel.app,https://custom-domain.com
CORS_ORIGIN=https://your-app.vercel.app

# Port — Railway/Render set this automatically; leave blank or set to 3001 locally
PORT=3001

# ── Frontend environment variables (set these in Vercel) ─────────────────────
# Public URL of your backend (Railway/Render URL, no trailing slash)
# This is NOT a secret — it's just your server's public address
SERVER_URL=https://your-backend.railway.app
